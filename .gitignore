# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool
*.out

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work

# IDE/Editor specific files
.idea/
.vscode/
*.swp
*.swo

# Environment variables file
.env

# Log files
*.log

# Build output
bin/
dist/

# OS-specific files
.DS_Store
Thumbs.db

# Ignore the binary generated by `go build`
/api

# Ignore local development configuration files
config.local.yaml
config.local.json

# Ignore local database files (if using SQLite, for example)
*.db
*.sqlite

# Ignore generated documentation
/docs/generated

# Ignore coverage reports
coverage.txt
coverage.html
